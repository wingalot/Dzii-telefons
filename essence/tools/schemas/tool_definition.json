{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tool Definition Schema",
  "type": "object",
  "required": ["name", "description", "version", "entry_point"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Tool identifier (snake_case)"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable description"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version"
    },
    "author": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["system", "ai", "web", "media", "comms", "utility"]
    },
    "entry_point": {
      "type": "string",
      "description": "Main executable or script path"
    },
    "requires_root": {
      "type": "boolean",
      "default": false
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "parameters": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "type": "object",
          "required": ["type", "description"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["string", "number", "boolean", "array", "object", "path"]
            },
            "description": { "type": "string" },
            "required": { "type": "boolean", "default": true },
            "default": {},
            "enum": { "type": "array" }
          }
        }
      }
    },
    "returns": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
